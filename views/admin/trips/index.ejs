<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trips - Fleet Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background: #f5f7fa; font-family: 'Outfit', sans-serif; }
        .main-content { margin-left: 280px; padding: 30px; }
        .page-title { font-size: 28px; font-weight: 700; margin-bottom: 20px; }
        .table-card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .status-badge { padding: 5px 12px; border-radius: 999px; font-size: 0.85rem; font-weight: 600; }
        .status-badge.pending, .status-badge.scheduled { background: rgba(243,156,18,0.16); color: #d68910; }
        .status-badge.ongoing, .status-badge.started { background: rgba(52,152,219,0.16); color: #2980b9; }
        .status-badge.completed { background: rgba(46,204,113,0.16); color: #27ae60; }
        .status-badge.cancelled { background: rgba(231,76,60,0.16); color: #c0392b; }
    </style>
</head>
<body>
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title">Trips</h1>
            <p class="text-secondary">Manage trips with driver and vehicle assignment details.</p>
        </div>
        <a href="/admin/trips/add" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Trip</a>
    </div>

    <div class="table-card mb-4">
        <form class="row g-3 align-items-end" method="GET" action="/admin/trips">
            <div class="col-md-4">
                <label class="form-label" for="status">Filter by Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <% statusOptions.forEach((option) => { %>
                        <option value="<%= option.value %>" <%= selectedStatus === option.value ? 'selected' : '' %>><%= option.label %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Apply</button>
            </div>
        </form>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Trip Number</th>
                        <th>Vehicle</th>
                        <th>Driver</th>
                        <th>Route</th>
                        <th>Status</th>
                        <th>Distance (km)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (trips && trips.length > 0) { %>
                        <% trips.forEach((trip) => { %>
                            <tr>
                                <td><%= trip.trip_id || 'N/A' %></td>
                                <td><strong><%= trip.trip_number || 'N/A' %></strong></td>
                                <td><%= trip.vehicle ? (trip.vehicle.vehicle_type || trip.vehicle.vehicle_number || 'N/A') : 'N/A' %></td>
                                <td><%= trip.driver ? trip.driver.driver_name || 'N/A' : 'N/A' %></td>
                                <td><%= trip.start_location || '-' %> → <%= trip.end_location || '-' %></td>
                                <td>
                                    <% const status = (trip.trip_status || 'scheduled').toLowerCase(); %>
                                    <span class="status-badge <%= status %>"><%= status === 'scheduled' ? 'Pending' : status === 'started' ? 'Ongoing' : status.charAt(0).toUpperCase() + status.slice(1) %></span>
                                </td>
                                <td><%= trip.distance_km != null ? trip.distance_km : '-' %></td>
                                <td>
                                    <a href="/admin/trips/view/<%= trip.trip_id %>" class="btn btn-sm btn-outline-secondary me-2"><i class="fas fa-eye"></i></a>
                                    <a href="/admin/trips/edit/<%= trip.trip_id %>" class="btn btn-sm btn-outline-primary me-2"><i class="fas fa-edit"></i></a>
                                    <a href="/admin/trips/delete/<%= trip.trip_id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this trip?')"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No trips found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
