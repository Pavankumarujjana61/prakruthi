<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Driver Details - Fleet Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background: #f5f7fa; font-family: 'Outfit', sans-serif; }
        .main-content { margin-left: 280px; padding: 30px; }
        .detail-card { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06); }
        .page-header { font-size: 28px; font-weight: 700; margin-bottom: 16px; }
        .field-label { font-weight: 600; color: #444; }
        .field-value { font-size: 0.95rem; color: #333; }
        .status-badge { padding: 6px 14px; border-radius: 999px; font-weight: 600; }
        .status-badge.active { background: rgba(22,160,133,0.16); color: #16a085; }
        .status-badge.inactive { background: rgba(231,76,60,0.16); color: #c0392b; }
    </style>
</head>
<body>
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-header">Driver Details</h1>
            <p class="text-secondary">Review the driver profile and activity details.</p>
        </div>
        <div>
            <a href="/admin/drivers" class="btn btn-outline-secondary me-2"><i class="fas fa-arrow-left me-2"></i>Back</a>
            <a href="/admin/drivers/edit/<%= driver.driver_id %>" class="btn btn-primary"><i class="fas fa-edit me-2"></i>Edit</a>
        </div>
    </div>
    <div class="detail-card">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="mb-3">
                    <div class="field-label">Driver Name</div>
                    <div class="field-value"><%= driver.driver_name || 'N/A' %></div>
                </div>
                <div class="mb-3">
                    <div class="field-label">Phone Number</div>
                    <div class="field-value"><%= driver.phone_number || 'N/A' %></div>
                </div>
                <div class="mb-3">
                    <div class="field-label">License Number</div>
                    <div class="field-value"><%= driver.license_number || 'N/A' %></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <div class="field-label">Joining Date</div>
                    <div class="field-value"><%= driver.joining_date || 'N/A' %></div>
                </div>
                <div class="mb-3">
                    <div class="field-label">Status</div>
                    <div class="field-value">
                        <% const status = (driver.status || 'inactive').toLowerCase(); %>
                        <span class="status-badge <%= status === 'active' ? 'active' : 'inactive' %>">
                            <%= status === 'active' ? 'Active' : 'Inactive' %>
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="mb-3">
                    <div class="field-label">Address</div>
                    <div class="field-value"><%= driver.address || 'N/A' %></div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
