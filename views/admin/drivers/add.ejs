<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Driver - Fleet Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background: #f5f7fa; font-family: 'Outfit', sans-serif; }
        .main-content { margin-left: 280px; padding: 30px; }
        .form-card { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06); }
        .page-header { font-size: 28px; font-weight: 700; margin-bottom: 16px; }
        .form-label { font-weight: 600; }
        .alert-list { margin-bottom: 20px; }
    </style>
</head>
<body>
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-header">Add Driver</h1>
            <p class="text-secondary">Fill in driver details and save to add a new driver.</p>
        </div>
        <a href="/admin/drivers" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back to Drivers</a>
    </div>
    <div class="form-card">
        <% if (errors && errors.length) { %>
            <div class="alert alert-danger alert-list">
                <ul class="mb-0">
                    <% errors.forEach(error => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>
        <form method="POST" action="/admin/drivers/add">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" for="driver_name">Driver Name</label>
                    <input type="text" id="driver_name" name="driver_name" value="<%= (formData && formData.driver_name) || '' %>" class="form-control" placeholder="Enter name">
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="phone_number">Phone Number</label>
                    <input type="text" id="phone_number" name="phone_number" value="<%= (formData && formData.phone_number) || '' %>" class="form-control" placeholder="Enter phone number">
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="license_number">License Number</label>
                    <input type="text" id="license_number" name="license_number" value="<%= (formData && formData.license_number) || '' %>" class="form-control" placeholder="Enter license number">
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="joining_date">Joining Date</label>
                    <input type="date" id="joining_date" name="joining_date" value="<%= (formData && formData.joining_date) || '' %>" class="form-control">
                </div>
                <div class="col-12">
                    <label class="form-label" for="address">Address</label>
                    <textarea id="address" name="address" class="form-control" rows="3" placeholder="Enter address"><%= (formData && formData.address) || '' %></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="active" <%= (formData && formData.status) === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="inactive" <%= (formData && formData.status) === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    </select>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i>Save Driver</button>
            </div>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
