<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Drivers - Fleet Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background: #f5f7fa; font-family: 'Outfit', sans-serif; }
        .main-content { margin-left: 280px; padding: 30px; }
        .page-title { font-size: 28px; font-weight: 700; margin-bottom: 20px; }
        .table-card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .status-badge { padding: 5px 12px; border-radius: 999px; font-size: 0.85rem; font-weight: 600; }
        .status-badge.active { background: rgba(22,160,133,0.16); color: #16a085; }
        .status-badge.inactive { background: rgba(231,76,60,0.16); color: #c0392b; }
    </style>
</head>
<body>
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title">Drivers</h1>
            <p class="text-secondary">Manage all drivers in your fleet.</p>
        </div>
        <a href="/admin/drivers/add" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i> Add Driver
        </a>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>License</th>
                        <th>Status</th>
                        <th>Joining Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (drivers && drivers.length > 0) { %>
                        <% drivers.forEach((driver) => { %>
                            <tr>
                                <td><%= driver.driver_id || 'N/A' %></td>
                                <td><strong><%= driver.driver_name || 'N/A' %></strong></td>
                                <td><%= driver.phone_number || '-' %></td>
                                <td><%= driver.license_number || '-' %></td>
                                <td>
                                    <% const status = (driver.current_status || 'inactive').toLowerCase(); %>
                                    <span class="status-badge <%= status === 'active' ? 'active' : 'inactive' %>">
                                        <%= status === 'active' ? 'Active' : 'Inactive' %>
                                    </span>
                                </td>
                                <td><%= driver.joining_date || '-' %></td>
                                <td>
                                    <a class="btn btn-sm btn-outline-secondary me-2" href="/admin/drivers/view/<%= driver.driver_id %>">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a class="btn btn-sm btn-outline-primary me-2" href="/admin/drivers/edit/<%= driver.driver_id %>">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a class="btn btn-sm btn-outline-danger" href="/admin/drivers/delete/<%= driver.driver_id %>" onclick="return confirm('Delete this driver?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No drivers found yet. Use the Add Driver button to create a new driver.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
