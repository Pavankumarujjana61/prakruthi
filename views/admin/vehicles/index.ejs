<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Vehicles - Fleet Management</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f7fa;
            font-family: 'Outfit', sans-serif;
        }

        .main-content {
            margin-left: 280px;
            padding: 30px;
        }

        .page-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .table-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .active {
            background: rgba(26,188,156,0.2);
            color: #1abc9c;
        }

        .inactive {
            background: rgba(231,76,60,0.2);
            color: #e74c3c;
        }

        .actions a {
            margin-right: 10px;
            text-decoration: none;
            font-size: 14px;
        }

        .actions a.edit {
            color: #3498db;
        }

        .actions a.delete {
            color: #e74c3c;
        }
    </style>
</head>

<body>

<!-- Sidebar + Header -->
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>

<div class="main-content">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="page-title">Vehicles</h1>
        <a href="/admin/vehicles/add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Vehicle
        </a>
    </div>

    <div class="table-card">

        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Vehicle Name</th>
                    <th>Vehicle Number</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <% if (vehicles && vehicles.length > 0) { %>

                    <% vehicles.forEach((vehicle, index) => { %>
                        <tr>
                            <td><%= vehicle.vehicle_id || index + 1 %></td>

                            <td>
                                <strong><%= vehicle.vehicle_name || vehicle.vehicle_type || 'N/A' %></strong>
                            </td>

                            <td>
                                <%= vehicle.vehicle_number || '-' %>
                            </td>

                            <td>
                                <% if ((vehicle.current_status || '').toLowerCase() === 'active') { %>
                                    <span class="status-badge active">Active</span>
                                <% } else { %>
                                    <span class="status-badge inactive"><%= vehicle.current_status ? vehicle.current_status.charAt(0).toUpperCase() + vehicle.current_status.slice(1) : 'Inactive' %></span>
                                <% } %>
                            </td>

                            <td class="actions">
                                <a class="btn btn-sm btn-outline-primary me-2" href="/admin/vehicles/edit/<%= vehicle.vehicle_id %>">
                                    <i class="fas fa-edit"></i> Edit
                                </a>

                                <a class="btn btn-sm btn-outline-danger" href="/admin/vehicles/delete/<%= vehicle.vehicle_id %>"
                                   onclick="return confirm('Are you sure you want to delete this vehicle?')">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    <% }) %>

                <% } else { %>

                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No vehicles found
                        </td>
                    </tr>

                <% } %>

            </tbody>
        </table>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>