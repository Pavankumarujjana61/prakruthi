<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Vehicle - Fleet Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: #f5f7fa;
            font-family: 'Outfit', sans-serif;
        }
        .main-content {
            margin-left: 280px;
            padding: 30px;
        }
        .form-card {
            background: #fff;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        }
        .page-header {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 24px;
        }
        .form-label {
            font-weight: 600;
        }
        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.87rem;
            padding: 8px 12px;
            border-radius: 999px;
        }
        .badge-status.active { background: rgba(26,188,156,0.16); color: #16a085; }
        .badge-status.inactive { background: rgba(231,76,60,0.12); color: #c0392b; }
        .alert-list {
            margin-bottom: 18px;
        }
    </style>
</head>
<body>
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-header">Add Vehicle</h1>
            <p class="text-muted">Create a new vehicle record for the fleet.</p>
        </div>
        <a href="/admin/vehicles" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to Vehicles
        </a>
    </div>
    <div class="form-card">
        <% if (errors && errors.length) { %>
            <div class="alert alert-danger alert-list">
                <ul class="mb-0">
                    <% errors.forEach(error => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>
        <form method="POST" action="/admin/vehicles/add">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" for="vehicle_name">Vehicle Name</label>
                    <input type="text" id="vehicle_name" name="vehicle_name" value="<%= (formData && formData.vehicle_name) || '' %>" class="form-control" placeholder="Enter vehicle name">
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="vehicle_number">Vehicle Number</label>
                    <input type="text" id="vehicle_number" name="vehicle_number" value="<%= (formData && formData.vehicle_number) || '' %>" class="form-control" placeholder="Enter vehicle number">
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="active" <%= (formData && formData.status) === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="inactive" <%= (formData && formData.status) === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    </select>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-plus me-2"></i> Create Vehicle
                </button>
            </div>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
