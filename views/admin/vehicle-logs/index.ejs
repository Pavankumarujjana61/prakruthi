<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Vehicle Logs - Fleet Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <style>
        body {
            background: #f5f7fa;
            font-family: 'Outfit', sans-serif;
        }
        .main-content {
            margin-left: 280px;
            padding: 30px;
        }
        .page-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 20px;
        }
        .table-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }
        .badge-log-type {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 0.8rem;
            font-weight: 600;
            background: #eef5ff;
            color: #2563eb;
        }
        .dataTables_wrapper .dataTables_filter input {
            width: 300px;
            margin-left: 0.5rem;
        }
        .table-responsive {
            overflow-x: auto;
        }
    </style>
</head>
<body>
<%- include('../../partials/sidebar.ejs') %>
<%- include('../../partials/header.ejs') %>
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title">Vehicle Logs</h1>
            <p class="text-muted">Track every vehicle service and maintenance report in one place.</p>
        </div>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table id="vehicleLogsTable" class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Vehicle Number</th>
                        <th>Log Type</th>
                        <th>Summary</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (logs && logs.length > 0) { %>
                        <% logs.forEach((log, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= log.vehicle_number || 'N/A' %></td>
                                <td><span class="badge-log-type"><%= log.log_type %></span></td>
                                <td><%= log.summary || '---' %></td>
                                <td><%= log.created_at ? new Date(log.created_at).toLocaleDateString() : 'N/A' %></td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-primary view-log-btn"
                                            data-type="<%= log.log_type_key %>"
                                            data-id="<%= log.id %>">
                                        <i class="fas fa-eye"></i> View
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td class="text-center text-muted py-4">No vehicle logs found.</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="logDetailsModal" tabindex="-1" aria-labelledby="logDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="logDetailsModalLabel">Log Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <strong>Vehicle:</strong>
                    <span id="detailVehicleNumber">-</span>
                </div>
                <div class="mb-3">
                    <strong>Log Type:</strong>
                    <span id="detailLogType">-</span>
                </div>
                <div class="mb-3">
                    <strong>Summary:</strong>
                    <span id="detailSummary">-</span>
                </div>
                <div class="mb-3">
                    <strong>Date:</strong>
                    <span id="detailDate">-</span>
                </div>
                <div class="mb-3">
                    <strong>Full Details</strong>
                    <pre id="detailJson" class="p-3 bg-light rounded" style="white-space: pre-wrap; word-break: break-word;">Loading...</pre>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script>
    $(document).ready(function () {
        $('#vehicleLogsTable').DataTable({
            responsive: true,
            pageLength: 12,
            order: [[4, 'desc']],
            columnDefs: [{ orderable: false, targets: 5 }]
        });

        const logModal = new bootstrap.Modal(document.getElementById('logDetailsModal'));

        $('.view-log-btn').on('click', function () {
            const logType = $(this).data('type');
            const logId = $(this).data('id');

            if (!logType || !logId) {
                return;
            }

            $('#detailVehicleNumber').text('Loading...');
            $('#detailLogType').text('Loading...');
            $('#detailSummary').text('Loading...');
            $('#detailDate').text('Loading...');
            $('#detailJson').text('Loading...');

            fetch(`/admin/vehicle-logs/${logType}/${logId}`)
                .then((response) => response.json())
                .then((result) => {
                    if (result.success && result.data) {
                        const log = result.data;
                        $('#detailVehicleNumber').text(log.vehicle_number || 'N/A');
                        $('#detailLogType').text(log.log_type || 'N/A');
                        $('#detailSummary').text(log.summary || 'N/A');
                        $('#detailDate').text(log.created_at ? new Date(log.created_at).toLocaleString() : 'N/A');
                        $('#detailJson').text(JSON.stringify(log.details, null, 2));
                    } else {
                        $('#detailJson').text(result.error || 'Unable to fetch log details');
                    }
                })
                .catch((error) => {
                    $('#detailJson').text(error.message || 'Unable to fetch log details');
                });

            logModal.show();
        });
    });
</script>
</body>
</html>
