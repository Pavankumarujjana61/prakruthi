<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prakruthi Tyres - Fleet Management Dashboard</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #0f3460;
            --secondary: #16a085;
            --accent: #e94560;
            --success: #1abc9c;
            --warning: #f39c12;
            --danger: #e74c3c;
            --info: #3498db;
            --light: #ecf0f1;
            --dark: #2c3e50;
            --border-light: rgba(255, 255, 255, 0.1);
            --border-dark: rgba(0, 0, 0, 0.1);
            --text-primary: #1a1a1a;
            --text-secondary: #666;
            --text-light: #999;
            --bg-light: #f8f9fa;
            --bg-card: rgba(255, 255, 255, 0.88);
            --shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.12);
        }

        html, body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
            min-height: 100vh;
            color: var(--text-primary);
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, var(--primary) 0%, #0a1f3a 100%);
            border-right: 1px solid var(--border-light);
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
        }

        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 3px;
        }

        .sidebar-brand {
            padding: 32px 24px 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .brand-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--secondary) 0%, #13826a 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            margin-bottom: 12px;
            box-shadow: 0 8px 20px rgba(22, 160, 133, 0.3);
        }

        .brand-text {
            font-size: 18px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.5px;
        }

        .brand-sub {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.6);
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .sidebar-nav {
            padding: 24px 0;
        }

        .nav-item {
            margin: 0;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.7);
            padding: 14px 24px;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-left: 3px solid transparent;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-link i {
            width: 18px;
            text-align: center;
        }

        .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
            border-left-color: var(--secondary);
        }

        .nav-link.active {
            color: var(--secondary);
            background: rgba(22, 160, 133, 0.15);
            border-left-color: var(--secondary);
        }

        /* ===== HEADER ===== */
        .header {
            background: white;
            padding: 20px 32px;
            box-shadow: var(--shadow);
            position: fixed;
            top: 0;
            left: 280px;
            right: 0;
            z-index: 100;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .breadcrumb-nav {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .breadcrumb-item {
            color: var(--text-secondary);
        }

        .breadcrumb-item.active {
            color: var(--secondary);
            font-weight: 600;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .search-box {
            background: var(--bg-light);
            border: 2px solid var(--border-dark);
            border-radius: 10px;
            padding: 10px 16px;
            width: 300px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .search-box:focus {
            outline: none;
            border-color: var(--secondary);
            background: white;
            box-shadow: 0 0 0 3px rgba(22, 160, 133, 0.1);
        }

        .header-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--bg-light);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            font-size: 16px;
            transition: all 0.3s ease;
            position: relative;
        }

        .header-icon:hover {
            background: var(--secondary);
            color: white;
        }

        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            width: 20px;
            height: 20px;
            background: var(--danger);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--secondary) 0%, #13826a 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
        }

        .user-info h6 {
            margin: 0;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .user-info small {
            color: var(--text-light);
            font-size: 12px;
        }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin-left: 280px;
            margin-top: 80px;
            padding: 40px 32px;
            min-height: 100vh;
            background: linear-gradient(180deg, #f5f7fa 0%, #e9ecef 100%);
        }

        .page-header {
            margin-bottom: 40px;
            animation: slideInDown 0.6s ease-out;
        }

        .page-title {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 8px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .page-description {
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
        }

        /* ===== CARDS ===== */
        .stat-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--border-light);
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            animation: fadeInUp 0.6s ease-out;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, var(--secondary), transparent);
            opacity: 0;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card:hover::before {
            opacity: 0.05;
        }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 16px;
        }

        .stat-icon.primary {
            background: linear-gradient(135deg, rgba(15, 52, 96, 0.2), rgba(22, 160, 133, 0.2));
            color: var(--primary);
        }

        .stat-icon.success {
            background: linear-gradient(135deg, rgba(26, 188, 156, 0.2), rgba(46, 204, 113, 0.2));
            color: var(--success);
        }

        .stat-icon.warning {
            background: linear-gradient(135deg, rgba(243, 156, 18, 0.2), rgba(230, 126, 34, 0.2));
            color: var(--warning);
        }

        .stat-icon.danger {
            background: linear-gradient(135deg, rgba(233, 69, 96, 0.2), rgba(231, 76, 60, 0.2));
            color: var(--danger);
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-light);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 12px;
        }

        .stat-change {
            font-size: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 6px 10px;
            border-radius: 6px;
        }

        .stat-change.up {
            background: rgba(26, 188, 156, 0.15);
            color: var(--success);
        }

        .stat-change.down {
            background: rgba(233, 69, 96, 0.15);
            color: var(--danger);
        }

        /* ===== CHARTS SECTION ===== */
        .chart-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-light);
            border-radius: 16px;
            padding: 28px;
            box-shadow: var(--shadow);
            animation: fadeInUp 0.6s ease-out 0.1s both;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .chart-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .chart-options {
            display: flex;
            gap: 8px;
        }

        .btn-chart-option {
            background: none;
            border: 1px solid var(--border-dark);
            color: var(--text-light);
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .btn-chart-option:hover,
        .btn-chart-option.active {
            background: var(--secondary);
            border-color: var(--secondary);
            color: white;
        }

        .chart-placeholder {
            height: 300px;
            background: linear-gradient(135deg, rgba(22, 160, 133, 0.05), rgba(52, 152, 219, 0.05));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-light);
            font-size: 14px;
            position: relative;
            overflow: hidden;
        }

        .chart-bar {
            position: absolute;
            bottom: 0;
            width: 30px;
            background: linear-gradient(180deg, var(--secondary), #13826a);
            border-radius: 6px 6px 0 0;
            transition: all 0.3s ease;
        }

        .chart-bar:hover {
            filter: brightness(1.2);
        }

        /* ===== TABLE SECTION ===== */
        .table-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-light);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--shadow);
            animation: fadeInUp 0.6s ease-out 0.2s both;
        }

        .table-header {
            padding: 28px;
            border-bottom: 1px solid var(--border-dark);
        }

        .table-header h5 {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .table-responsive-custom {
            overflow-x: auto;
        }

        .table-custom {
            margin-bottom: 0;
        }

        .table-custom thead {
            background: var(--bg-light);
        }

        .table-custom th {
            border: none;
            padding: 16px 24px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-light);
            letter-spacing: 0.5px;
        }

        .table-custom td {
            border: none;
            padding: 16px 24px;
            font-size: 14px;
            border-bottom: 1px solid var(--border-dark);
        }

        .table-custom tbody tr:last-child td {
            border-bottom: none;
        }

        .table-custom tbody tr {
            transition: background-color 0.2s ease;
        }

        .table-custom tbody tr:hover {
            background: var(--bg-light);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-active {
            background: rgba(26, 188, 156, 0.2);
            color: var(--success);
        }

        .status-inactive {
            background: rgba(233, 69, 96, 0.2);
            color: var(--danger);
        }

        .status-pending {
            background: rgba(243, 156, 18, 0.2);
            color: var(--warning);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }

        /* ===== ANIMATIONS ===== */
        @keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 991px) {
            .sidebar {
                width: 240px;
            }

            .header {
                left: 240px;
            }

            .main-content {
                margin-left: 240px;
            }

            .search-box {
                width: 200px;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 0;
                transition: width 0.3s ease;
            }

            .sidebar.active {
                width: 240px;
            }

            .header {
                left: 0;
                padding: 16px 20px;
                height: 70px;
            }

            .main-content {
                margin-left: 0;
                margin-top: 70px;
                padding: 24px 16px;
            }

            .search-box {
                display: none;
            }

            .header-right {
                gap: 12px;
            }

            .page-title {
                font-size: 24px;
            }

            .stat-value {
                font-size: 24px;
            }

            .chart-placeholder {
                height: 250px;
            }

            .user-info {
                display: none;
            }

            .breadcrumb-nav {
                display: none;
            }
        }

        @media (max-width: 576px) {
            .header {
                flex-wrap: wrap;
                height: auto;
                padding: 12px 16px;
                gap: 12px;
            }

            .header-left,
            .header-right {
                width: 100%;
                justify-content: space-between;
            }

            .main-content {
                margin-top: auto;
                padding: 20px 12px;
            }

            .page-title {
                font-size: 20px;
            }

            .stat-card {
                padding: 20px;
            }

            .chart-card,
            .table-card {
                padding: 20px;
            }

            .table-custom th,
            .table-custom td {
                padding: 12px;
                font-size: 12px;
            }
        }

        /* ===== MOBILE MENU TOGGLE ===== */
        .menu-toggle {
            display: none;
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 20px;
            cursor: pointer;
        }

        @media (max-width: 768px) {
            .menu-toggle {
                display: flex;
            }
        }
    </style>
</head>
<body>

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <i class="fas fa-truck-moving"></i>
            </div>
            <div class="brand-text">Prakruthi Tyres</div>
            <div class="brand-sub">Fleet Management</div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="#" class="nav-link active">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-truck"></i>
                    <span>Vehicles</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-users"></i>
                    <span>Drivers</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-route"></i>
                    <span>Routes & Tracking</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-box"></i>
                    <span>Deliveries</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-wrench"></i>
                    <span>Maintenance</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-chart-bar"></i>
                    <span>Reports</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </div>
        </nav>
    </aside>

    <!-- ===== HEADER ===== -->
    <header class="header">
        <div class="header-left">
            <button class="menu-toggle" id="menuToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="breadcrumb-nav">
                <span class="breadcrumb-item">Dashboard</span>
                <span style="color: var(--text-light);">/</span>
                <span class="breadcrumb-item active">Overview</span>
            </div>
        </div>

        <div class="header-right">
            <input type="text" class="search-box" placeholder="Search vehicles, drivers, routes...">
            
            <button class="header-icon">
                <i class="fas fa-bell"></i>
                <span class="notification-badge">3</span>
            </button>
            
            <button class="header-icon">
                <i class="fas fa-message"></i>
            </button>

            <div class="user-profile">
                <div class="user-avatar">
                    <span>AM</span>
                </div>
                <div class="user-info">
                    <h6>Admin Manager</h6>
                    <small>System Admin</small>
                </div>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">
        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">Welcome Back, Admin</h1>
            <p class="page-description">Track your entire fleet performance and manage logistics efficiently</p>
        </div>

        <!-- Stats Cards Row 1 -->
        <div class="row mb-5">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon primary">
                        <i class="fas fa-truck"></i>
                    </div>
                    <div class="stat-label">Total Vehicles</div>
                    <div class="stat-value">248</div>
                    <span class="stat-change up">
                        <i class="fas fa-arrow-up"></i>
                        8.2% this month
                    </span>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon success">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-label">Active Drivers</div>
                    <div class="stat-value">156</div>
                    <span class="stat-change up">
                        <i class="fas fa-arrow-up"></i>
                        12 new this week
                    </span>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon warning">
                        <i class="fas fa-road"></i>
                    </div>
                    <div class="stat-label">Active Routes</div>
                    <div class="stat-value">42</div>
                    <span class="stat-change up">
                        <i class="fas fa-arrow-up"></i>
                        3.5% increase
                    </span>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon danger">
                        <i class="fas fa-box"></i>
                    </div>
                    <div class="stat-label">Pending Deliveries</div>
                    <div class="stat-value">18</div>
                    <span class="stat-change down">
                        <i class="fas fa-arrow-down"></i>
                        2.1% decrease
                    </span>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="row mb-5">
            <div class="col-lg-8">
                <div class="chart-card">
                    <div class="chart-header">
                        <h5 class="chart-title">Fleet Performance</h5>
                        <div class="chart-options">
                            <button class="btn-chart-option active">Weekly</button>
                            <button class="btn-chart-option">Monthly</button>
                            <button class="btn-chart-option">Yearly</button>
                        </div>
                    </div>
                    <div class="chart-placeholder">
                        <div style="position: absolute; bottom: 0; left: 10%; height: 60%; width: 8%; background: linear-gradient(180deg, var(--secondary), #13826a); border-radius: 6px 6px 0 0;"></div>
