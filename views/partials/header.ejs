<!-- Header Partial -->

<style>
    :root {
        --primary: #0f3460;
        --secondary: #16a085;
        --accent: #e94560;
        --text-primary: #1a1a1a;
        --text-secondary: #666;
        --text-light: #999;
        --border-dark: rgba(0, 0, 0, 0.1);
        --bg-light: #f8f9fa;
        --shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    }

    .header {
        background: white;
        padding: 20px 32px;
        box-shadow: var(--shadow);
        position: fixed;
        top: 0;
        left: 280px;
        right: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 80px;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
    }

    .breadcrumb-item {
        color: var(--text-secondary);
    }

    .breadcrumb-item.active {
        color: var(--secondary);
        font-weight: 600;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .search-box {
        background: var(--bg-light);
        border: 2px solid var(--border-dark);
        border-radius: 10px;
        padding: 10px 16px;
        width: 300px;
        font-size: 14px;
        transition: all 0.3s ease;
        font-family: 'Outfit', sans-serif;
    }

    .search-box:focus {
        outline: none;
        border-color: var(--secondary);
        background: white;
        box-shadow: 0 0 0 3px rgba(22, 160, 133, 0.1);
    }

    .header-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--bg-light);
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        font-size: 16px;
        transition: all 0.3s ease;
        position: relative;
    }

    .header-icon:hover {
        background: var(--secondary);
        color: white;
    }

    .notification-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        width: 20px;
        height: 20px;
        background: var(--accent);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 8px 12px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .user-profile:hover {
        background: var(--bg-light);
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--secondary) 0%, #13826a 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 16px;
    }

    .user-info h6 {
        margin: 0;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .user-info small {
        color: var(--text-light);
        font-size: 12px;
    }

    .dropdown-menu {
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        box-shadow: var(--shadow);
        background: white;
    }

    .dropdown-item {
        padding: 12px 16px;
        font-size: 14px;
        color: var(--text-secondary);
    }

    .dropdown-item:hover {
        background: var(--bg-light);
        color: var(--secondary);
    }

    @media (max-width: 768px) {

        .header {
            left: 0;
            padding: 16px 20px;
        }

        .search-box {
            display: none;
        }

        .user-info {
            display: none;
        }

        .breadcrumb-nav {
            display: none;
        }
    }
</style>

<header class="header">

    <div class="header-left">

        <div class="breadcrumb-nav">

            <span class="breadcrumb-item">
                <%= typeof breadcrumbFirst !== 'undefined'
                    ? breadcrumbFirst
                    : 'Dashboard' %>
            </span>

            <span style="color: var(--text-light);">/</span>

            <span class="breadcrumb-item active">
                <%= typeof breadcrumbSecond !== 'undefined'
                    ? breadcrumbSecond
                    : 'Overview' %>
            </span>

        </div>

    </div>

    <div class="header-right">

        <input
            type="text"
            class="search-box"
            placeholder="Search..."
        >

        <button class="header-icon">

            <i class="fas fa-bell"></i>

            <span class="notification-badge">

                <%= typeof unreadNotifications !== 'undefined'
                    ? unreadNotifications
                    : 3 %>

            </span>

        </button>

        <div class="dropdown">

            <div
                class="user-profile"
                data-bs-toggle="dropdown"
            >

                <div class="user-avatar">

                    <%= admin && admin.name
                        ? admin.name.charAt(0).toUpperCase()
                        : 'A' %>

                </div>

                <div class="user-info">

                    <h6>

                        <%= admin && admin.name
                            ? admin.name
                            : 'Admin' %>

                    </h6>

                    <small>System Admin</small>

                </div>

                <i
                    class="fas fa-chevron-down"
                    style="font-size:12px;color:var(--text-light);"
                ></i>

            </div>

            <ul class="dropdown-menu dropdown-menu-end">

                <li>

                    <a
                        class="dropdown-item"
                        href="/admin/dashboard"
                    >
                        <i class="fas fa-home me-2"></i>
                        Dashboard
                    </a>

                </li>

                <li>

                    <a
                        class="dropdown-item"
                        href="/admin/profile"
                    >
                        <i class="fas fa-user me-2"></i>
                        Profile
                    </a>

                </li>

                <li><hr class="dropdown-divider"></li>

                <li>

                    <a
                        class="dropdown-item"
                        href="/admin/logout"
                    >
                        <i class="fas fa-sign-out-alt me-2"></i>
                        Logout
                    </a>

                </li>

            </ul>

        </div>

    </div>

</header>

<!-- Notifications Modal -->

<div
    class="modal fade"
    id="notificationModal"
    tabindex="-1"
>

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">

                    Notifications

                </h5>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                ></button>

            </div>

            <div class="modal-body">

                <% if (
                    typeof notifications !== 'undefined' &&
                    notifications.length > 0
                ) { %>

                    <% notifications.forEach(notif => { %>

                        <div
                            style="
                                padding:12px;
                                border-bottom:1px solid #eee;
                            "
                        >

                            <h6>
                                <%= notif.title %>
                            </h6>

                            <p>
                                <%= notif.message %>
                            </p>

                        </div>

                    <% }) %>

                <% } else { %>

                    <div
                        style="
                            text-align:center;
                            padding:30px;
                        "
                    >

                        No notifications

                    </div>

                <% } %>

            </div>

        </div>

    </div>

</div>