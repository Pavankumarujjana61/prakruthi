            </div>

            <div class="nav-item">
                <a href="/admin/vehicle-logs" class="nav-link <%= currentPage === 'vehicle_logs' ? 'active' : '' %>">
                    <i class="fas fa-route"></i>
                    <span>Vehicle Logs</span>
                </a>
            </div>
        </div>

        <!-- Operations -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">Operations</div>
            
            <div class="nav-item">
                <a href="/admin/deliveries" class="nav-link <%= currentPage === 'deliveries' ? 'active' : '' %>">
                    <i class="fas fa-box"></i>
