<!-- Sidebar Partial -->
<style>
    :root {
        --primary: #0f3460;
        --secondary: #16a085;
        --accent: #e94560;
        --text-primary: #1a1a1a;
        --text-secondary: #666;
        --text-light: #999;
        --border-light: rgba(255, 255, 255, 0.1);
        --bg-light: #f8f9fa;
        --shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    }

    /* ===== SIDEBAR ===== */
    .sidebar {
        width: 280px;
        background: linear-gradient(180deg, var(--primary) 0%, #0a1f3a 100%);
        border-right: 1px solid var(--border-light);
        position: fixed;
        left: 0;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        z-index: 1000;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
        padding-top: 0;
        margin: 0;
    }

    .sidebar::-webkit-scrollbar {
        width: 6px;
    }

    .sidebar::-webkit-scrollbar-track {
        background: transparent;
    }

    .sidebar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 3px;
    }

    .sidebar-brand {
        padding: 32px 24px 24px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .brand-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--secondary) 0%, #13826a 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
        margin-bottom: 12px;
        box-shadow: 0 8px 20px rgba(22, 160, 133, 0.3);
    }

    .brand-text {
        font-size: 18px;
        font-weight: 700;
        color: white;
        letter-spacing: -0.5px;
    }

    .brand-sub {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.6);
        margin-top: 4px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .sidebar-nav {
        padding: 24px 0;
        list-style: none;
    }

    .nav-item {
        margin: 0;
    }

    .nav-link {
        color: rgba(255, 255, 255, 0.7);
        padding: 14px 24px;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-left: 3px solid transparent;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        cursor: pointer;
    }

    .nav-link i {
        width: 18px;
        text-align: center;
    }

    .nav-link:hover {
        color: white;
        background: rgba(255, 255, 255, 0.05);
        border-left-color: var(--secondary);
    }

    .nav-link.active {
        color: var(--secondary);
        background: rgba(22, 160, 133, 0.15);
        border-left-color: var(--secondary);
    }

    .sidebar-section {
        margin-top: 32px;
    }

    .sidebar-section-title {
        padding: 12px 24px;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.5);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .sidebar {
            width: 0;
            transition: width 0.3s ease;
        }

        .sidebar.active {
            width: 240px;
        }
    }
</style>

