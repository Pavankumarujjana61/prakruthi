                </a>
            </div>

            <div class="nav-item">
                <a href="/admin/maintenance" class="nav-link <%= currentPage === 'maintenance' ? 'active' : '' %>">
                    <i class="fas fa-wrench"></i>
                    <span>Maintenance</span>
                </a>
            </div>

            <div class="nav-item">
                <a href="/admin/routes" class="nav-link <%= currentPage === 'routes' ? 'active' : '' %>">
                    <i class="fas fa-map"></i>
